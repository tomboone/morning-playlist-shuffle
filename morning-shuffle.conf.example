# Morning Shuffle Configuration
# Copy this file to morning-shuffle.conf and fill in your values.
# After changing values, run: ~/Scripts/morning-shuffle-install.sh

# Comma-separated keywords that together uniquely identify your playlist.
# All keywords must match (using "contains" logic) against playlist names.
# Examples:
#   PLAYLIST_MATCH="My Morning Mix"         (single keyword, matches exactly one playlist)
#   PLAYLIST_MATCH="Today,Indie Rock"       (two keywords, useful if the name has curly quotes)
PLAYLIST_MATCH=""

EQMAC_DEVICE=""
PLAY_HOUR=8
PLAY_MINUTE=30
VOLUME=40
SYSTEM_VOLUME=50

# iCloud Drive flag directory.
# The iPhone shortcut saves play.flag or skip.flag here.
# Use a hardcoded absolute path — launchd may not resolve $HOME reliably.
FLAG_DIR="/Users/YOURUSERNAME/Library/Mobile Documents/com~apple~CloudDocs/MorningShuffle"
